{
  "version": 3,
  "configurePresets": [
    {
      "name": "bin",
      "binaryDir": "${sourceDir}/build/bin",
      "cacheVariables": {
        "BUILD_BIN": "ON",
        "BUILD_LIB": "OFF"
      }
    },
    {
      "name": "lib",
      "binaryDir": "${sourceDir}/build/lib",
      "cacheVariables": {
        "BUILD_BIN": "OFF",
        "BUILD_LIB": "ON"
      }
    }
  ]
}
