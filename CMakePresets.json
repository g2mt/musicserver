{
  "version": 3,
  "configurePresets": [
    {
      "name": "bin",
      "binaryDir": "${sourceDir}/build/bin",
      "cacheVariables": {
        "MS_BUILD_BIN": "ON",
        "MS_BUILD_LIB": "OFF"
      }
    },
    {
      "name": "android",
      "cacheVariables": {
        "MS_STATIC_TAGLIB": "ON",
        "MS_BUILD_ANDROID": "ON",
        "MS_BUILD_BIN": "OFF",
        "MS_BUILD_LIB": "ON"
      }
    },

    {
      "name": "x86_64-android",
      "binaryDir": "${sourceDir}/build/x86_64-android",
      "inherits": ["android"],
      "cacheVariables": {
        "MS_GOARCH": "amd64",
        "MS_SYSROOT_TRIPLET": "x86_64-linux-android",
        "MS_APKARCH": "x86_64"
      }
    },
    {
      "name": "armv7a-android",
      "binaryDir": "${sourceDir}/build/armv7a-android",
      "inherits": ["android"],
      "cacheVariables": {
        "MS_GOARCH": "arm",
        "MS_SYSROOT_TRIPLET": "arm-linux-androideabi",
        "MS_APKARCH": "armeabi-v7a"
      }
    },
    {
      "name": "aarch64-android",
      "binaryDir": "${sourceDir}/build/aarch64-android",
      "inherits": ["android"],
      "cacheVariables": {
        "MS_GOARCH": "arm64",
        "MS_SYSROOT_TRIPLET": "aarch64-linux-android",
        "MS_APKARCH": "arm64-v8a"
      }
    }
  ]
}
